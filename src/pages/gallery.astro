    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            // -----------------------------
            // SOURCE OF TRUTH
            // -----------------------------
            var galleryItems = Array.from(document.querySelectorAll('.gallery-item'));

            var state = {
                activeFilter: 'all',
                items: galleryItems.map(function (item) {
                    return {
                        el: item,
                        category: item.dataset.category,
                        visible: true,
                    };
                }),
            };

            // -----------------------------
            // FILTER UI
            // -----------------------------
            var filterBtns = document.querySelectorAll('.filter-btn');
            var emptyState = document.getElementById('empty-state');

            function applyFilter(filter) {
                state.activeFilter = filter;

                var visibleCount = 0;

                state.items.forEach(function (item) {
                    var match = filter === 'all' || item.category === filter;
                    item.visible = match;

                    if (match) {
                        item.el.style.display = '';
                        item.el.style.opacity = '1';
                        item.el.style.transform = 'scale(1)';
                        visibleCount++;
                    } else {
                        item.el.style.opacity = '0';
                        item.el.style.transform = 'scale(0.95)';
                        setTimeout(function () {
                            item.el.style.display = 'none';
                        }, 200);
                    }
                });

                if (emptyState) {
                    emptyState.classList.toggle('hidden', visibleCount > 0);
                }
            }

            filterBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    filterBtns.forEach(function (b) {
                        b.classList.remove('active', 'bg-sage', 'text-white');
                        b.classList.add('bg-sage/10', 'text-sage');
                    });

                    btn.classList.add('active', 'bg-sage', 'text-white');
                    btn.classList.remove('bg-sage/10', 'text-sage');

                    applyFilter(btn.dataset.filter);
                });
            });
        });
    </script>
